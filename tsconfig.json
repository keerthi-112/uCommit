{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "types": ["node"],

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": [
  "src/**/*",
  "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}

